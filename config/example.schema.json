        "limit_type": {"type": "str", "required": false, "default": "daily"},
        "limit_count": {"type": "int", "required": false, "default": 1},
        "start_time": {"type": "str", "required": false},
        "end_time": {"type": "str", "required": false},
        "creator": {"type": "str", "required": false},
        "create_time": {"type": "str", "required": false},
        "internal_note": {"type": "str", "required": false}
      },
      "field_aliases": {
