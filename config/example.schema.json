        "名称": "name",
        "价格ID": "price_id",
        "价格 ID": "price_id",
        "限购类型": "limit_type",
        "限购次数": "limit_count",
        "开始时间": "start_time",
        "结束时间": "end_time"
      }
    },
    "reward_item_config": {
      "sheet": "reward_item_config",
      "primary_key": ["reward_group_id", "item_order"],
      "group_key": "reward_group_id",
      "overwrite_strategy": "group_replace",
      "ai_write_permission": "supervised_write",
      "allow_update_fields": ["reward_group_id", "item_id", "item_count", "item_order"],
      "preserve_fields": [],
      "fields": {
        "reward_group_id": {"type": "int", "required": true},
        "item_id": {"type": "int", "required": true},
        "item_count": {"type": "int", "required": true},
        "item_order": {"type": "int", "required": true}
      },
