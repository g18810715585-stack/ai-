# ChatGPT / Gemini / Claude / DeepSeek all go through company BI / BaseAI.
BASEAI_API_KEY=
BASEAI_BASE_URL=https://baseai.rivergame.net/v1
CHATGPT_MODEL=gpt-5.5
GEMINI_MODEL=gemini-3.1-pro-preview
CLAUDE_MODEL=claude-opus-4-8
DEEPSEEK_MODEL=deepseek-v4-pro

# Optional: limit AI draft output to reduce long waits. Set to 0 to disable the limit.
AI_MAX_OUTPUT_TOKENS=7000
# Optional: only enable if your company BI gateway supports it, for example low/medium/high.
AI_REASONING_EFFORT=

# Optional: point Node CLI/server at a specific Python executable.
AI_META_AGENT_PYTHON=
